# ── Linguist language-stats tuning ───────────────────────────────────────────
# Exclude THIRD-PARTY vendored libraries (not first-party code) from the
# repository language breakdown. Argon2 is a bundled WASM/JS dependency.
crypto/vendor/**            linguist-vendored
**/argon2-bundled.min.js    linguist-vendored
*.min.js                    linguist-vendored

