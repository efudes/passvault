# PassVault backend environment. Copy to /opt/passvault/.env on the server.
# setup.sh GENERATES a real .env with strong random secrets if one is absent,
# so you normally never edit secrets by hand. NEVER commit a filled-in .env.

# Domain the Mini App + API are served from (must have a valid TLS cert).
DOMAIN=example.com

# CORS allow-list (comma-separated). The Mini App is same-origin so it does not
# strictly need an entry; the browser extension origin is appended in M5.
ALLOWED_ORIGINS=https://example.com

# Auth secrets — leave blank; setup.sh fills them with `openssl rand -hex 48`
# directly on the server. They are never stored in the repo.
JWT_SECRET=
SERVER_HMAC_SECRET=

# Telegram Mini App bot token (needed in M6; blank is fine for M4).
TELEGRAM_BOT_TOKEN=

# Absolute SQLite path. The data dir is created 700 and owned by the service user.
PASSVAULT_DB=/opt/passvault/data/passvault.db

# JWT access-token lifetime (hours).
JWT_TTL_HOURS=12

# ---------------------------------------------------------------------------
# Offsite backup -> Cloudflare R2 (optional). If any of the R2_* values or
# BACKUP_ENCRYPTION_KEY are left blank, backup.sh does the LOCAL backup only and
# logs a warning (it never fails). Fill these IN ON THE SERVER ONLY; never commit.
#
# Create an R2 bucket + an R2 API token (Object Read & Write) in the Cloudflare
# dashboard. The token gives you the Access Key ID and Secret Access Key. The
# endpoint is https://<ACCOUNT_ID>.r2.cloudflarestorage.com .
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# Backup encryption secret. With age (default — setup.sh installs it) this MUST be
# an age secret key: generate it OFFLINE with `age-keygen` and paste the line that
# starts with AGE-SECRET-KEY-1...  (keep a copy somewhere safe — without it the
# offsite backups cannot be decrypted). If only gpg is available, this is instead
# a strong passphrase. Backups are named passvault-YYYYMMDD-HHMMSS.age (or .gpg).
BACKUP_ENCRYPTION_KEY=
